{
  "entities": {
    "Wedding": {
      "title": "Wedding Event",
      "description": "Metadata for a wedding event.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "watermarkEnabled": { "type": "boolean" },
        "watermarkText": { "type": "string" },
        "watermarkPosition": { "type": "string", "enum": ["top-left", "top-right", "bottom-left", "bottom-right", "center"] },
        "watermarkOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "watermarkBg": { "type": "string" },
        "watermarkTextSize": { "type": "number" },
        "liquidGlassEnabled": { "type": "boolean" },
        "photoBlur": { "type": "number" },
        "coverUrl": { "type": "string" },
        "sharingLimit": { "type": "string", "enum": ["1h", "10h", "1d", "unlimited"] },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "date", "ownerId"]
    },
    "Photo": {
      "title": "Wedding Photo",
      "description": "A photo from a wedding event.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "weddingId": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "faceEncoding": { "type": "string", "description": "Simulated string representation of face features" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "weddingId", "uploadedBy"]
    },
    "Profile": {
      "title": "User Profile",
      "description": "Personalized settings and metadata for a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "about": { "type": "string" },
        "photoURL": { "type": "string" },
        "favoriteSubject": { "type": "string" },
        "savedPhotos": { 
          "type": "array",
          "items": { "$ref": "#/entities/Photo" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/weddings/{weddingId}": {
      "schema": "Wedding",
      "description": "Stores wedding metadata."
    },
    "/weddings/{weddingId}/photos/{photoId}": {
      "schema": "Photo",
      "description": "Stores photos for a specific wedding."
    },
    "/profiles/{userId}": {
      "schema": "Profile",
      "description": "Stores user profile data."
    }
  }
}
